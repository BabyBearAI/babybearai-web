# ===== BabyBear Offer Mailer — SMTP 配置 =====
# 把本文件复制为 ".env" 并填入你的发信凭据。
# send-offer.js 只需要「SMTP 发信」能力，下面任选一种免费方案即可。
# 详细图文步骤见 EMAIL-SETUP.md

# ---- 方案 A：Brevo 免费 SMTP（推荐，每天 300 封免费）----
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-login@smtp-brevo.com      # Brevo 后台给你的 SMTP login
SMTP_PASS=your-brevo-smtp-key            # Brevo 的 SMTP key（不是登录密码）

# ---- 方案 B：Zoho 邮箱 SMTP（如果你开了 Zoho 邮箱）----
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=admissions@babybearai.com
# SMTP_PASS=your-app-password

# ---- 发件人显示信息（用你自己的域名地址）----
FROM_NAME=BabyBear 小熊双语夏令营
FROM_EMAIL=admissions@babybearai.com     # 必须是 babybearai.com 下、已完成域名验证的地址
REPLY_TO=hello@babybearai.com            # 家长点「回复」时的收件地址

# 可选：把每封 offer 抄送一份到自己邮箱存档
# BCC=records@babybearai.com
